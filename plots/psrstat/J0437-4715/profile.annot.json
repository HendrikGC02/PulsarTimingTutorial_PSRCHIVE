{
  "format": "psrstat -c \"all:bin:mean\"",
  "describes": "One value per phase bin (1024 rows by default) — the integrated intensity at that bin.  Plot this and you have the profile.",
  "spans": [
    {
      "line": 9999,
      "start": 0,
      "end": 0,
      "kind": "flag",
      "label": "bin index  (0..nbin-1)"
    },
    {
      "line": 9999,
      "start": 0,
      "end": 0,
      "kind": "frequency",
      "label": "mean intensity in that bin"
    }
  ]
}
